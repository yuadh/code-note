    556          /*********************************************************************
    557           * @fn      GenericApp_SendTheMessage
    558           *
    559           * @brief   Send "the" message.
    560           *
    561           * @param   none
    562           *
    563           * @return  none
    564           */
    565          static void GenericApp_SendTheMessage( void )
    566          {
    567            char theMessageData[] = "Hello World";
    568          
    569            if ( AF_DataRequest( &GenericApp_DstAddr, &GenericApp_epDesc,
    570                                 GENERICAPP_CLUSTERID,
    571                                 (byte)osal_strlen( theMessageData ) + 1,
    572                                 (byte *)&theMessageData,
    573                                 &GenericApp_TransID,
    574                                 AF_DISCV_ROUTE, AF_DEFAULT_RADIUS ) == afStatus_SUCCESS )
    575            {
    576              // Successfully requested to be sent.
    577            }
    578            else
    579            {
    580              // Error occurred in request to send.
    581            }
    582          }
