    585          /*********************************************************************
    586           * @fn      GenericApp_ProcessRtosMessage
    587           *
    588           * @brief   Receive message from RTOS queue, send response back.
    589           *
    590           * @param   none
    591           *
    592           * @return  none
    593           */
    594          static void GenericApp_ProcessRtosMessage( void )
    595          {
    596            osalQueue_t inMsg;
    597          
    598            if ( osal_queue_receive( OsalQueue, &inMsg, 0 ) == pdPASS )
    599            {
    600              uint8 cmndId = inMsg.cmnd;
    601              uint32 counter = osal_build_uint32( inMsg.cbuf, 4 );
    602          
    603              switch ( cmndId )
    604              {
    605                case CMD_INCR:
    606                  counter += 1;  /* Increment the incoming counter */
    607                                 /* Intentionally fall through next case */
    608          
    609                case CMD_ECHO:
    610                {
    611                  userQueue_t outMsg;
    612          
    613                  outMsg.resp = RSP_CODE | cmndId;  /* Response ID */
    614                  osal_buffer_uint32( outMsg.rbuf, counter );    /* Increment counter */
    615                  osal_queue_send( UserQueue1, &outMsg, 0 );  /* Send back to UserTask */
    616                  break;
    617                }
    618          
    619                default:
    620                  break;  /* Ignore unknown command */
    621              }
    622            }
    623          }
    624          #endif
