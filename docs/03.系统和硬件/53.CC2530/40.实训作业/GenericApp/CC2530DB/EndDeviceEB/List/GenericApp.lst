    492          /*********************************************************************
    493           * @fn      GenericApp_MessageMSGCB
    494           *
    495           * @brief   Data message processor callback.  This function processes
    496           *          any incoming data - probably from other devices.  So, based
    497           *          on cluster ID, perform the intended action.
    498           *
    499           * @param   none
    500           *
    501           * @return  none
    502           */
    503          static void GenericApp_MessageMSGCB( afIncomingMSGPacket_t *pkt )
    504          {
    505            switch ( pkt->clusterId )
    506            {
    507              case GENERICAPP_CLUSTERID:
    508                // "the" message
    509          #if defined( LCD_SUPPORTED )
    510                HalLcdWriteScreen( (char*)pkt->cmd.Data, "rcvd" );
    511          #elif defined( WIN32 )
    512                WPRINTSTR( pkt->cmd.Data );
    513          #endif
    514                break;
    515            }
    516          }
    517          
    518          /*********************************************************************
    519           * @fn      GenericApp_SendTheMessage
    520           *
    521           * @brief   Send "the" message.
    522           *
    523           * @param   none
    524           *
    525           * @return  none
    526           */
    527          static void GenericApp_SendTheMessage( void )
    528          {
    529            char theMessageData[] = "Hello World";
    530          
    531            if ( AF_DataRequest( &GenericApp_DstAddr, &GenericApp_epDesc,
    532                                 GENERICAPP_CLUSTERID,
    533                                 (byte)osal_strlen( theMessageData ) + 1,
    534                                 (byte *)&theMessageData,
    535                                 &GenericApp_TransID,
    536                                 AF_DISCV_ROUTE, AF_DEFAULT_RADIUS ) == afStatus_SUCCESS )
    537            {
    538              // Successfully requested to be sent.
    539            }
    540            else
    541            {
    542              // Error occurred in request to send.
    543            }
    544          }
