    546          #if defined( IAR_ARMCM3_LM )
    547          /*********************************************************************
    548           * @fn      GenericApp_ProcessRtosMessage
    549           *
    550           * @brief   Receive message from RTOS queue, send response back.
    551           *
    552           * @param   none
    553           *
    554           * @return  none
    555           */
    556          static void GenericApp_ProcessRtosMessage( void )
    557          {
    558            osalQueue_t inMsg;
    559          
    560            if ( osal_queue_receive( OsalQueue, &inMsg, 0 ) == pdPASS )
    561            {
    562              uint8 cmndId = inMsg.cmnd;
    563              uint32 counter = osal_build_uint32( inMsg.cbuf, 4 );
    564          
    565              switch ( cmndId )
    566              {
    567                case CMD_INCR:
    568                  counter += 1;  /* Increment the incoming counter */
    569                                 /* Intentionally fall through next case */
    570          
    571                case CMD_ECHO:
    572                {
    573                  userQueue_t outMsg;
    574          
    575                  outMsg.resp = RSP_CODE | cmndId;  /* Response ID */
    576                  osal_buffer_uint32( outMsg.rbuf, counter );    /* Increment counter */
    577                  osal_queue_send( UserQueue1, &outMsg, 0 );  /* Send back to UserTask */
    578                  break;
    579                }
    580          
    581                default:
    582                  break;  /* Ignore unknown command */
    583              }
    584            }
    585          }
    586          #endif
