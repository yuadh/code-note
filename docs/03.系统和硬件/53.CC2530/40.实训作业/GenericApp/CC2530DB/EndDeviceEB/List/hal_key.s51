//  194  * @fn      HalKeyInit
//  195  *
//  196  * @brief   Initilize Key Service
//  197  *
//  198  * @param   none
//  199  *
//  200  * @return  None
//  201  **************************************************************************************************/

        RSEG BANKED_CODE:CODE:NOROOT(0)
//  202 void HalKeyInit( void )
HalKeyInit:
        CFI Block cfiBlock0 Using cfiCommon0
        CFI Function HalKeyInit
        CODE
//  203 {
        PUSH    DPL
        CFI DPL0 Frame(CFA_SP, 4)
        CFI CFA_SP SP+-4
        PUSH    DPH
        CFI DPH0 Frame(CFA_SP, 5)
        CFI CFA_SP SP+-5
        ; Saved register size: 2
        ; Auto size: 0
//  204   /* Initialize previous key to 0 */
//  205   halKeySavedKeys = 0;
        MOV     DPTR,#halKeySavedKeys
        CLR     A
        MOVX    @DPTR,A
//  206 
//  207   HAL_KEY_SW_6_SEL &= ~(HAL_KEY_SW_6_BIT);    /* Set pin function to GPIO */
        ANL     0xf3,#0xfd
//  208   HAL_KEY_SW_6_DIR &= ~(HAL_KEY_SW_6_BIT);    /* Set pin direction to Input */
        ANL     0xfd,#0xfd
//  209 
//  210   HAL_KEY_SW_7_SEL &= ~(HAL_KEY_SW_7_BIT);    /* Set pin function to GPIO */
        ANL     0xf4,#0xfb
//  211   HAL_KEY_SW_7_DIR &= ~(HAL_KEY_SW_7_BIT);    /* Set pin direction to Input */
        ANL     0xfe,#0xfb
//  212 
//  213   HAL_KEY_JOY_MOVE_SEL &= ~(HAL_KEY_JOY_MOVE_BIT); /* Set pin function to GPIO */
        ANL     0xf5,#0xfe
//  214   HAL_KEY_JOY_MOVE_DIR &= ~(HAL_KEY_JOY_MOVE_BIT); /* Set pin direction to Input */
        ANL     0xff,#0xfe
//  215 
//  216 
//  217   /* Initialize callback function */
//  218   pHalKeyProcessFunction  = NULL;
        MOV     DPTR,#pHalKeyProcessFunction
        MOVX    @DPTR,A
        INC     DPTR
        MOVX    @DPTR,A
//  219 
//  220   /* Start with key is not configured */
//  221   HalKeyConfigured = FALSE;
        MOV     DPTR,#HalKeyConfigured
        MOVX    @DPTR,A
//  222 }
        LJMP    ?Subroutine0 & 0xFFFF
        CFI EndBlock cfiBlock0
        REQUIRE P0SEL
        REQUIRE P0DIR
        REQUIRE P1SEL
        REQUIRE P1DIR
        REQUIRE P2SEL
        REQUIRE P2DIR
//  223 
//  224 
//  225 /**************************************************************************************************
//  226  * @fn      HalKeyConfig
//  227  *
//  228  * @brief   Configure the Key serivce
//  229  *
//  230  * @param   interruptEnable - TRUE/FALSE, enable/disable interrupt
//  231  *          cback - pointer to the CallBack function
//  232  *
//  233  * @return  None
//  234  **************************************************************************************************/

        RSEG BANKED_CODE:CODE:NOROOT(0)
//  235 void HalKeyConfig (bool interruptEnable, halKeyCBack_t cback)
HalKeyConfig:
        CFI Block cfiBlock1 Using cfiCommon0
        CFI Function HalKeyConfig
        CODE
//  236 {
        FUNCALL HalKeyConfig, osal_stop_timerEx
        LOCFRAME ISTACK, 0, STACK
        LOCFRAME PSTACK, 0, STACK
        LOCFRAME XSTACK, 9, STACK
        LOCFRAME IOVERLAY, 0, STATIC
        LOCFRAME DOVERLAY, 0, STATIC
        ARGFRAME ISTACK, 0, STACK
        ARGFRAME PSTACK, 0, STACK
        ARGFRAME XSTACK, 9, STACK
        ARGFRAME IOVERLAY, 0, STATIC
        ARGFRAME DOVERLAY, 0, STATIC
        FUNCALL HalKeyConfig, osal_set_event
        LOCFRAME ISTACK, 0, STACK
        LOCFRAME PSTACK, 0, STACK
        LOCFRAME XSTACK, 9, STACK
        LOCFRAME IOVERLAY, 0, STATIC
        LOCFRAME DOVERLAY, 0, STATIC
        ARGFRAME ISTACK, 0, STACK
        ARGFRAME PSTACK, 0, STACK
        ARGFRAME XSTACK, 9, STACK
        ARGFRAME IOVERLAY, 0, STATIC
        ARGFRAME DOVERLAY, 0, STATIC
        MOV     A,#-0x9
        LCALL   ?BANKED_ENTER_XDATA
        CFI DPH0 load(1, XDATA, add(CFA_XSP16, literal(-1)))
        CFI DPL0 load(1, XDATA, add(CFA_XSP16, literal(-2)))
        CFI ?BRET_EXT load(1, XDATA, add(CFA_XSP16, literal(-3)))
        CFI ?RET_HIGH load(1, XDATA, add(CFA_XSP16, literal(-4)))
        CFI ?RET_LOW load(1, XDATA, add(CFA_XSP16, literal(-5)))
        CFI R7 load(1, XDATA, add(CFA_XSP16, literal(-6)))
        CFI V0 load(1, XDATA, add(CFA_XSP16, literal(-7)))
        CFI VB load(1, XDATA, add(CFA_XSP16, literal(-8)))
        CFI R6 load(1, XDATA, add(CFA_XSP16, literal(-9)))
        CFI CFA_SP SP+0
        CFI CFA_XSP16 add(XSP16, 9)
        ; Saved register size: 9
        ; Auto size: 0
        MOV     A,R1
//  237   /* Enable/Disable Interrupt or */
//  238   Hal_KeyIntEnable = interruptEnable;
        MOV     DPTR,#Hal_KeyIntEnable
        MOVX    @DPTR,A
//  239 
//  240   /* Register the callback fucntion */
//  241   pHalKeyProcessFunction = cback;
        MOV     DPTR,#pHalKeyProcessFunction
        MOV     A,R2
        MOVX    @DPTR,A
        INC     DPTR
        MOV     A,R3
        MOVX    @DPTR,A
//  242 
//  243   /* Determine if interrupt is enable or not */
//  244   if (Hal_KeyIntEnable)
        MOV     DPTR,#Hal_KeyIntEnable
        MOVX    A,@DPTR
        JZ      ??HalKeyConfig_0
//  245   {
//  246     /* Rising/Falling edge configuratinn */
//  247 
//  248     PICTL &= ~(HAL_KEY_SW_6_EDGEBIT);    /* Clear the edge bit */
        ANL     0x8c,#0xfe
//  249     PICTL &= ~(HAL_KEY_SW_7_EDGEBIT);
        ANL     0x8c,#0xfd
//  250     /* For falling edge, the bit must be set. */
//  251   #if (HAL_KEY_SW_6_EDGE == HAL_KEY_FALLING_EDGE)
//  252     PICTL |= HAL_KEY_SW_6_EDGEBIT;
        ORL     0x8c,#0x1
//  253   #endif
//  254   #if (HAL_KEY_SW_7_EDGE == HAL_KEY_FALLING_EDGE)
//  255     PICTL |= HAL_KEY_SW_7_EDGEBIT;
        ORL     0x8c,#0x2
//  256   #endif
//  257 
//  258 
//  259     /* Interrupt configuration:
//  260      * - Enable interrupt generation at the port
//  261      * - Enable CPU interrupt
//  262      * - Clear any pending interrupt
//  263      */
//  264     HAL_KEY_SW_6_ICTL |= HAL_KEY_SW_6_ICTLBIT;
        ORL     0xab,#0x2
//  265     HAL_KEY_SW_6_IEN |= HAL_KEY_SW_6_IENBIT;
        SETB    0xb8.5
//  266     HAL_KEY_SW_6_PXIFG = ~(HAL_KEY_SW_6_BIT);
        MOV     0x89,#-0x3
//  267 
//  268     HAL_KEY_SW_7_ICTL |= HAL_KEY_SW_7_ICTLBIT;
        ORL     0x8d,#0x4
//  269     HAL_KEY_SW_7_IEN |= HAL_KEY_SW_7_IENBIT;
        ORL     0x9a,#0x10
//  270     HAL_KEY_SW_7_PXIFG = ~(HAL_KEY_SW_7_BIT);
        MOV     0x8a,#-0x5
//  271 
//  272     /* Rising/Falling edge configuratinn */
//  273 
//  274     HAL_KEY_JOY_MOVE_ICTL &= ~(HAL_KEY_JOY_MOVE_EDGEBIT);    /* Clear the edge bit */
        ANL     0xac,#0xf7
//  275     /* For falling edge, the bit must be set. */
//  276   #if (HAL_KEY_JOY_MOVE_EDGE == HAL_KEY_FALLING_EDGE)
//  277     HAL_KEY_JOY_MOVE_ICTL |= HAL_KEY_JOY_MOVE_EDGEBIT;
        ORL     0xac,#0x8
//  278   #endif
//  279 
//  280 
//  281     /* Interrupt configuration:
//  282      * - Enable interrupt generation at the port
//  283      * - Enable CPU interrupt
//  284      * - Clear any pending interrupt
//  285      */
//  286     HAL_KEY_JOY_MOVE_ICTL |= HAL_KEY_JOY_MOVE_ICTLBIT;
        ORL     0xac,#0x1
//  287     HAL_KEY_JOY_MOVE_IEN |= HAL_KEY_JOY_MOVE_IENBIT;
        ORL     0x9a,#0x2
//  288     HAL_KEY_JOY_MOVE_PXIFG = ~(HAL_KEY_JOY_MOVE_BIT);
        MOV     0x8b,#-0x2
//  289 
//  290 
//  291     /* Do this only after the hal_key is configured - to work with sleep stuff */
//  292     if (HalKeyConfigured == TRUE)
        MOV     DPTR,#HalKeyConfigured
        MOVX    A,@DPTR
        XRL     A,#0x1
        JNZ     ??HalKeyConfig_1
//  293     {
//  294       osal_stop_timerEx(Hal_TaskID, HAL_KEY_EVENT);  /* Cancel polling if active */
        ; Setup parameters for call to function osal_stop_timerEx
        MOV     R2,#0x1
        MOV     R3,#0x0
        MOV     DPTR,#Hal_TaskID
        MOVX    A,@DPTR
        MOV     R1,A
        LCALL   ??osal_stop_timerEx?relay
        SJMP    ??HalKeyConfig_1
//  295     }
//  296   }
//  297   else    /* Interrupts NOT enabled */
//  298   {
//  299     HAL_KEY_SW_6_ICTL &= ~(HAL_KEY_SW_6_ICTLBIT); /* don't generate interrupt */
??HalKeyConfig_0:
        ANL     0xab,#0xfd
//  300     HAL_KEY_SW_6_IEN &= ~(HAL_KEY_SW_6_IENBIT);   /* Clear interrupt enable bit */
        CLR     0xb8.5
//  301 
//  302     HAL_KEY_SW_7_ICTL &= ~(HAL_KEY_SW_7_ICTLBIT); /* don't generate interrupt */
        ANL     0x8d,#0xfb
//  303     HAL_KEY_SW_7_IEN &= ~(HAL_KEY_SW_7_IENBIT);   /* Clear interrupt enable bit */
        ANL     0x9a,#0xef
//  304 
//  305     osal_set_event(Hal_TaskID, HAL_KEY_EVENT);
        ; Setup parameters for call to function osal_set_event
        MOV     R2,#0x1
        MOV     R3,#0x0
        MOV     DPTR,#Hal_TaskID
        MOVX    A,@DPTR
        MOV     R1,A
        LCALL   ??osal_set_event?relay
//  306   }
//  307 
//  308   /* Key now is configured */
//  309   HalKeyConfigured = TRUE;
??HalKeyConfig_1:
        MOV     DPTR,#HalKeyConfigured
        MOV     A,#0x1
        MOVX    @DPTR,A
//  310 }
        MOV     R7,A
        LJMP    ?BANKED_LEAVE_XDATA
        CFI EndBlock cfiBlock1
        REQUIRE PICTL
        REQUIRE P0IEN
        REQUIRE _A_IEN1
        REQUIRE P0IFG
        REQUIRE P1IEN
        REQUIRE IEN2
        REQUIRE P1IFG
        REQUIRE P2IEN
        REQUIRE P2IFG
//  311 
//  312 
//  313 /**************************************************************************************************
//  314  * @fn      HalKeyRead
//  315  *
//  316  * @brief   Read the current value of a key
//  317  *
//  318  * @param   None
//  319  *
//  320  * @return  keys - current keys status
//  321  **************************************************************************************************/

        RSEG BANKED_CODE:CODE:NOROOT(0)
//  322 uint8 HalKeyRead ( void )
HalKeyRead:
        CFI Block cfiBlock2 Using cfiCommon0
        CFI Function HalKeyRead
        CODE
//  323 {
        FUNCALL HalKeyRead, halGetJoyKeyInput
        LOCFRAME ISTACK, 0, STACK
        LOCFRAME PSTACK, 0, STACK
        LOCFRAME XSTACK, 9, STACK
        LOCFRAME IOVERLAY, 0, STATIC
        LOCFRAME DOVERLAY, 0, STATIC
        ARGFRAME ISTACK, 0, STACK
        ARGFRAME PSTACK, 0, STACK
        ARGFRAME XSTACK, 9, STACK
        ARGFRAME IOVERLAY, 0, STATIC
        ARGFRAME DOVERLAY, 0, STATIC
        MOV     A,#-0x9
        LCALL   ?BANKED_ENTER_XDATA
        CFI DPH0 load(1, XDATA, add(CFA_XSP16, literal(-1)))
