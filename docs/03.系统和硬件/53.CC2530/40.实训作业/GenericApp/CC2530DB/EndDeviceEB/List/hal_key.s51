//  101 #define HAL_KEY_RISING_EDGE   0
//  102 #define HAL_KEY_FALLING_EDGE  1
//  103 
//  104 #define HAL_KEY_DEBOUNCE_VALUE  25
//  105 
//  106 /* CPU port interrupt */
//  107 #define HAL_KEY_CPU_PORT_0_IF P0IF
//  108 #define HAL_KEY_CPU_PORT_1_IF P1IF
//  109 #define HAL_KEY_CPU_PORT_2_IF P2IF
//  110 
//  111 /* SW_6 is at P0.1 */
//  112 #define HAL_KEY_SW_6_PORT   P0
//  113 #define HAL_KEY_SW_6_BIT    BV(1)
//  114 #define HAL_KEY_SW_6_SEL    P0SEL
//  115 #define HAL_KEY_SW_6_DIR    P0DIR
//  116 
//  117 /* edge interrupt */
//  118 #define HAL_KEY_SW_6_EDGEBIT  BV(0)
//  119 #define HAL_KEY_SW_6_EDGE     HAL_KEY_FALLING_EDGE   //ĎÂ˝µÔ´´Ą·˘
//  120 
//  121 
//  122 /* SW_6 interrupts */
//  123 #define HAL_KEY_SW_6_IEN      IEN1  /* CPU interrupt mask register */
//  124 #define HAL_KEY_SW_6_IENBIT   BV(5) /* Mask bit for all of Port_0 */
//  125 #define HAL_KEY_SW_6_ICTL     P0IEN /* Port Interrupt Control register */
//  126 #define HAL_KEY_SW_6_ICTLBIT  BV(1) /* P0IEN - P0.1 enable/disable bit */
//  127 #define HAL_KEY_SW_6_PXIFG    P0IFG /* Interrupt flag at source */
//  128 ////////////////////////////////////
//  129 /* SW_7 is at P1.2 */
//  130 #define HAL_KEY_SW_7_PORT   P1
//  131 #define HAL_KEY_SW_7_BIT    BV(2)
//  132 #define HAL_KEY_SW_7_SEL    P1SEL
//  133 #define HAL_KEY_SW_7_DIR    P1DIR
//  134 
//  135 /* edge interrupt */
//  136 #define HAL_KEY_SW_7_EDGEBIT  BV(1)
//  137 #define HAL_KEY_SW_7_EDGE     HAL_KEY_FALLING_EDGE   //ĎÂ˝µÔ´´Ą·˘
//  138 
//  139 /* SW_7 interrupts */
//  140 #define HAL_KEY_SW_7_IEN      IEN2  /* CPU interrupt mask register */
//  141 #define HAL_KEY_SW_7_IENBIT   BV(4) /* Mask bit for all of Port_0 */
//  142 #define HAL_KEY_SW_7_ICTL     P1IEN /* Port Interrupt Control register */
//  143 #define HAL_KEY_SW_7_ICTLBIT  BV(2) /* P0IEN - P0.1 enable/disable bit */
//  144 #define HAL_KEY_SW_7_PXIFG    P1IFG /* Interrupt flag at source */
//  145 
//  146 ////////////////////////////////////
//  147 /* Joy stick move at P2.0 */
//  148 #define HAL_KEY_JOY_MOVE_PORT   P2
//  149 #define HAL_KEY_JOY_MOVE_BIT    BV(0)
//  150 #define HAL_KEY_JOY_MOVE_SEL    P2SEL
//  151 #define HAL_KEY_JOY_MOVE_DIR    P2DIR
//  152 
//  153 /* edge interrupt */
//  154 #define HAL_KEY_JOY_MOVE_EDGEBIT  BV(3)
//  155 #define HAL_KEY_JOY_MOVE_EDGE     HAL_KEY_FALLING_EDGE
//  156 
//  157 /* Joy move interrupts */
//  158 #define HAL_KEY_JOY_MOVE_IEN      IEN2  /* CPU interrupt mask register */
//  159 #define HAL_KEY_JOY_MOVE_IENBIT   BV(1) /* Mask bit for all of Port_2 */
//  160 #define HAL_KEY_JOY_MOVE_ICTL     P2IEN /* Port Interrupt Control register */
//  161 #define HAL_KEY_JOY_MOVE_ICTLBIT  BV(0) /* P2IENL - P2.0<->P2.3 enable/disable bit */
//  162 #define HAL_KEY_JOY_MOVE_PXIFG    P2IFG /* Interrupt flag at source */
//  163 
//  164 #define HAL_KEY_JOY_CHN   HAL_ADC_CHANNEL_6
