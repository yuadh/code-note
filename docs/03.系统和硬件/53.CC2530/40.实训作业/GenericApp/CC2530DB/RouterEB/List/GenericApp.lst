    520          /*********************************************************************
    521           * @fn      GenericApp_MessageMSGCB
    522           *
    523           * @brief   Data message processor callback.  This function processes
    524           *          any incoming data - probably from other devices.  So, based
    525           *          on cluster ID, perform the intended action.
    526           *
    527           * @param   none
    528           *
    529           * @return  none
    530           */
    531          static void GenericApp_MessageMSGCB( afIncomingMSGPacket_t *pkt )
    532          {
    533            switch ( pkt->clusterId )
    534            {
    535              case GENERICAPP_CLUSTERID:
    536                // "the" message
    537          #if defined( LCD_SUPPORTED )
    538                HalLcdWriteScreen( (char*)pkt->cmd.Data, "rcvd" );
    539          #elif defined( WIN32 )
    540                WPRINTSTR( pkt->cmd.Data );
    541          #endif
    542                break;
    543            }
    544          }
    545          
    546          /*********************************************************************
    547           * @fn      GenericApp_SendTheMessage
    548           *
    549           * @brief   Send "the" message.
    550           *
    551           * @param   none
    552           *
    553           * @return  none
    554           */
    555          static void GenericApp_SendTheMessage( void )
    556          {
    557            char theMessageData[] = "Hello World";
    558          
    559            if ( AF_DataRequest( &GenericApp_DstAddr, &GenericApp_epDesc,
    560                                 GENERICAPP_CLUSTERID,
    561                                 (byte)osal_strlen( theMessageData ) + 1,
    562                                 (byte *)&theMessageData,
    563                                 &GenericApp_TransID,
    564                                 AF_DISCV_ROUTE, AF_DEFAULT_RADIUS ) == afStatus_SUCCESS )
    565            {
    566              // Successfully requested to be sent.
    567            }
    568            else
    569            {
    570              // Error occurred in request to send.
    571            }
    572          }
    573          
    574          #if defined( IAR_ARMCM3_LM )
    575          /*********************************************************************
    576           * @fn      GenericApp_ProcessRtosMessage
    577           *
    578           * @brief   Receive message from RTOS queue, send response back.
    579           *
    580           * @param   none
    581           *
    582           * @return  none
    583           */
    584          static void GenericApp_ProcessRtosMessage( void )
    585          {
    586            osalQueue_t inMsg;
    587          
    588            if ( osal_queue_receive( OsalQueue, &inMsg, 0 ) == pdPASS )
    589            {
    590              uint8 cmndId = inMsg.cmnd;
    591              uint32 counter = osal_build_uint32( inMsg.cbuf, 4 );
    592          
    593              switch ( cmndId )
    594              {
    595                case CMD_INCR:
    596                  counter += 1;  /* Increment the incoming counter */
    597                                 /* Intentionally fall through next case */
    598          
    599                case CMD_ECHO:
    600                {
    601                  userQueue_t outMsg;
    602          
    603                  outMsg.resp = RSP_CODE | cmndId;  /* Response ID */
    604                  osal_buffer_uint32( outMsg.rbuf, counter );    /* Increment counter */
    605                  osal_queue_send( UserQueue1, &outMsg, 0 );  /* Send back to UserTask */
    606                  break;
    607                }
    608          
    609                default:
    610                  break;  /* Ignore unknown command */
    611              }
    612            }
    613          }
    614          #endif
