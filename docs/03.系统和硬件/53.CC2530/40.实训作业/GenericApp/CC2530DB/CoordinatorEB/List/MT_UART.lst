    328          #if defined (ZAPP_P1) || defined (ZAPP_P2)
    329          /***************************************************************************************************
    330           * @fn      MT_UartProcessZAppData
    331           *
    332           * @brief   | SOP | CMD  |   Data Length   | FSC  |
    333           *          |  1  |  2   |       1         |  1   |
    334           *
    335           *          Parses the data and determine either is SPI or just simply serial data
    336           *          then send the data to correct place (MT or APP)
    337           *
    338           * @param   port    - UART port
    339           *          event   - Event that causes the callback
    340           *
    341           *
    342           * @return  None
    343           ***************************************************************************************************/
    344          void MT_UartProcessZAppData ( uint8 port, uint8 event )
    345          {
    346          
    347            osal_event_hdr_t  *msg_ptr;
    348            uint16 length = 0;
    349            uint16 rxBufLen  = Hal_UART_RxBufLen(MT_UART_DEFAULT_PORT);
    350          
    351            /*
    352               If maxZAppBufferLength is 0 or larger than current length
    353               the entire length of the current buffer is returned.
    354            */
    355            if ((MT_UartMaxZAppBufLen != 0) && (MT_UartMaxZAppBufLen <= rxBufLen))
    356            {
    357              length = MT_UartMaxZAppBufLen;
    358            }
    359            else
    360            {
    361              length = rxBufLen;
    362            }
    363          
    364            /* Verify events */
    365            if (event == HAL_UART_TX_FULL)
    366            {
    367              // Do something when TX if full
    368              return;
    369            }
    370          
    371            if (event & ( HAL_UART_RX_FULL | HAL_UART_RX_ABOUT_FULL | HAL_UART_RX_TIMEOUT))
    372            {
    373              if ( App_TaskID )
    374              {
    375                /*
    376                   If Application is ready to receive and there is something
    377                   in the Rx buffer then send it up
    378                */
    379                if ((MT_UartZAppRxStatus == MT_UART_ZAPP_RX_READY ) && (length != 0))
    380                {
    381                  /* Disable App flow control until it processes the current data */
    382                   MT_UartAppFlowControl (MT_UART_ZAPP_RX_NOT_READY);
    383          
    384                  /* 2 more bytes are added, 1 for CMD type, other for length */
    385                  msg_ptr = (osal_event_hdr_t *)osal_msg_allocate( length + sizeof(osal_event_hdr_t) );
    386                  if ( msg_ptr )
    387                  {
    388                    msg_ptr->event = SPI_INCOMING_ZAPP_DATA;
    389                    msg_ptr->status = length;
    390          
    391                    /* Read the data of Rx buffer */
    392                    HalUARTRead( MT_UART_DEFAULT_PORT, (uint8 *)(msg_ptr + 1), length );
    393          
    394                    /* Send the raw data to application...or where ever */
    395                    osal_msg_send( App_TaskID, (uint8 *)msg_ptr );
    396                  }
    397                }
    398              }
    399            }
    400          }
    401          
    402          /***************************************************************************************************
    403           * @fn      SPIMgr_ZAppBufferLengthRegister
    404           *
    405           * @brief
    406           *
    407           * @param   maxLen - Max Length that the application wants at a time
    408           *
    409           * @return  None
    410           *
    411           ***************************************************************************************************/
    412          void MT_UartZAppBufferLengthRegister ( uint16 maxLen )
    413          {
    414            /* If the maxLen is larger than the RX buff, something is not right */
    415            if (maxLen <= MT_UART_DEFAULT_MAX_RX_BUFF)
    416              MT_UartMaxZAppBufLen = maxLen;
    417            else
    418              MT_UartMaxZAppBufLen = 1; /* default is 1 byte */
    419          }
    420          
    421          /***************************************************************************************************
    422           * @fn      SPIMgr_AppFlowControl
    423           *
    424           * @brief
    425           *
    426           * @param   status - ready to send or not
    427           *
    428           * @return  None
    429           *
    430           ***************************************************************************************************/
    431          void MT_UartAppFlowControl ( bool status )
    432          {
    433          
    434            /* Make sure only update if needed */
    435            if (status != MT_UartZAppRxStatus )
    436            {
    437              MT_UartZAppRxStatus = status;
    438            }
    439          
    440            /* App is ready to read again, ProcessZAppData have to be triggered too */
    441            if (status == MT_UART_ZAPP_RX_READY)
    442            {
    443              MT_UartProcessZAppData (MT_UART_DEFAULT_PORT, HAL_UART_RX_TIMEOUT );
    444            }
    445          
    446          }
    447          
    448          #endif //ZAPP
