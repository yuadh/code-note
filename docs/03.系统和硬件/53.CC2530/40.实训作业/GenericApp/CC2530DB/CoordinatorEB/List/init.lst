     21          //****中断 sw_1 sw_2 初始化
     22          void init_btn(int sta){ //设置上升沿还是下降沿  0是上升沿 1是下降沿
     23            //对SW1的中断使能
     24            IEN2 |= 0x10;     //使能P1端口组外部中断（IEN2不能位操作）0001 0000
     25            P1IEN |= 0x04;    //使能P1_2引脚外部中断 0000 0100
     26            //对SW2的中断使能 0010 0000
     27            IEN1 |= 0x20; //是P0端口组
     28            P0IEN |= 0x02;  //0000 0010
     29            if(sta){//下降沿触发
     30              PICTL |= 0x02;   //配置P1_0到P1_3上升沿触发 0010
     31              PICTL |= 0X01; //设置上升沿触发
     32            }else{//上升沿触发
     33              PICTL &= ~0x02;   //配置P1_0到P1_3上升沿触发 0010
     34              PICTL &= ~0X01; //设置上升沿触发
     35            }
     36            EA = 1;       //打开总中断
     37          }
     38          // ****延时函数
     39          void Delay(unsigned int t)
     40          {
     41            int i;
     42            while(t--){
     43              for(i=0;i<255;i++);
     44            }
     45          }
     46          void Init_WDT(int sta)
     47          {
     48            if(sta){
     49              WDCTL |= 0x0c;  //0000 1100
     50              IEN2 |= 0x20;  //开启看门狗中断
     51              EA = 1;//开启总中断
     52            }else{
     53              WDCTL |= 0x08;  //看门狗模式 时间间隔为1s
     54            }
     55          }
